# CSU Marketplace Environment Variables

# React App Environment Variables
# Copy this file to .env and fill in your actual values

# Contract Address (V6.6 - Wallet-Agnostic - Nov 18, 2025)
VITE_MARKETPLACE_CONTRACT_ADDRESS=0x3F1fa083D1103e6fea9e3Dd6c1E95b4505Ac6564

# Alchemy Configuration
REACT_APP_ALCHEMY_API_KEY=
REACT_APP_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Development Settings
REACT_APP_NETWORK=sepolia
REACT_APP_CHAIN_ID=11155111

# Supabase Configuration
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Admin Addresses (comma-separated)
REACT_APP_INITIAL_ADMIN_ADDRESSES=