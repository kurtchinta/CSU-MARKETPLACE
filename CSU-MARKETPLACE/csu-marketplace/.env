# =============================================================================
# BLOCKCHAIN CONFIGURATION
# =============================================================================

# Alchemy Sepolia testnet RPC URL
# Get from: https://www.alchemy.com/
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Private key for deployment (without 0x prefix)
# NEVER share this or commit it to version control
SEPOLIA_PRIVATE_KEY=your_private_key_here

# Etherscan API key for contract verification
# Get from: https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key

# Gas reporting (set to true to enable)
REPORT_GAS=false

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

# Supabase Project URL
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (Public Key)
# Safe to use in frontend - has limited permissions based on RLS policies
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (Private Key)
# NEVER expose this in frontend - use only in backend/server operations
# Has full database access - bypasses Row Level Security (RLS)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment mode
NODE_ENV=development

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:3000

# API Base URL
API_BASE_URL=http://localhost:3001